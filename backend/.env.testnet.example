# Official Nami testnet receiving server — copy to backend/.env

NAMI_NETWORK=testnet
# From deployments/testnet/latest.json (2026-06-23 publish)
NAMI_PACKAGE_ID=0x74f2e6f200d7a814390b89e2e8a1c7d09fb49968a4362c8ab56e100e9573665f
NAMI_ADMIN_CAP_ID=0xf4ff9561a7b9dc736b6c9e47b1806fd2e9eeb5eb699e475f86bb82e0cb6258bd
NAMI_NODENAME_REGISTRY_ID=0x68e1b656a5fbb5534577f64321fb466512e8534da8749821b085ac8687891fa7
NAMI_PUBLISH_DIGEST=BzH6uKy2Hg82f9UvDYqcNGtpZzYXMWjveqqFxqHWwCWX

NAMI_TEST_LAUNCH=true
NAMI_OFFICIAL_OWNER=0xbcf5a725b72f88fd50c7146a48822fc61e3691cbe44193a668887de4573764ca
NAMI_OFFICIAL_OWNER_EMAIL=robbier640@gmail.com
NAMI_OFFICIAL_NODENAME=fiendtgnceo
NAMI_OFFICIAL_ARCHETYPE=1
NAMI_OFFICIAL_AVATAR_REF=seed:official-owner
# Optional bech32 suiprivkey for scripts/mint-enter-nami.mjs (official owner wallet only)
NAMI_MINT_SIGNER_SECRET=
# Optional server-side sync token for ops/cron (never ship to frontend)
NAMI_OFFICIALS_SYNC_SECRET=

NAMI_POLL_INTERVAL_MS=5000
NAMI_PAGE_LIMIT=50
NAMI_MAX_PAGES_PER_MODULE=5
NAMI_CURSOR_PATH=data/cursors.json
NAMI_EVENT_LOG_PATH=data/events.jsonl
NAMI_HTTP_PORT=8787
# Public Render URL (no trailing slash) — used for nodename/media absolute links
NAMI_PUBLIC_API_URL=https://nami-backend-rv0o.onrender.com

# Optional ops alerts (Slack/Discord/PagerDuty-compatible JSON POST)
NAMI_ALERT_WEBHOOK_URL=
NAMI_ALERT_FAILURE_THRESHOLD=3

# Testnet policy — mock checkout disabled when NAMI_TEST_LAUNCH=true
NAMI_PAYMENT_ALLOW_MOCK=false
NAMI_REQUIRE_WALLET_AUTH=true
NAMI_PAYMENT_SUCCESS_URL=https://nami-fiends.vercel.app/?payment=success
NAMI_PAYMENT_CANCEL_URL=https://nami-fiends.vercel.app/?payment=cancel
NAMI_PAYMENT_TREASURY_ADDRESS=0x6bff7988b87ffce3af4eaee7853f77b6d0d9ebb0e70a2a5924e5bdc7f68c75b4

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NAMI_PAYPAL_MODE=sandbox

# Channel ownership transfer invites (Resend)
RESEND_API_KEY=
NAMI_TRANSFER_EMAIL_FROM=Nami <onboarding@yourdomain.com>
NAMI_TRANSFER_PORTAL_URL=https://nami-fiends.vercel.app

# Border art — Walrus Quilt (BA-14.1). Mysten testnet publisher is public; no signer key required.
NAMI_WALRUS_NETWORK=testnet
NAMI_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NAMI_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NAMI_WALRUS_STORAGE_EPOCHS=5
# BA-14.2: set true after migrating existing Render border-art files off disk
# NAMI_WALRUS_BORDER_ART_REQUIRED=false

# Phase 9.1 — Walrus Sites static SPA (after first site-builder deploy)
# NAMI_WALRUS_SITE_OBJECT_ID=0x...
# NAMI_WALRUS_SITE_NETWORK=testnet
# NAMI_WALRUS_SITE_EPOCHS=5

# Phase 9.2 — Seal privacy envelopes (off by default)
# NAMI_SEAL_PRIVACY_ENABLED=false
