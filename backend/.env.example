# devnet | testnet | mainnet | localnet
NAMI_NETWORK=testnet

# Published Nami package ID after deployment
NAMI_PACKAGE_ID=0xYOUR_PACKAGE_ID_HERE

# Optional for localnet only
SUI_FULLNODE_URL=http://127.0.0.1:9000

# Indexer settings
NAMI_POLL_INTERVAL_MS=5000
NAMI_PAGE_LIMIT=50
NAMI_MAX_PAGES_PER_MODULE=5

# Local indexer files
NAMI_CURSOR_PATH=data/cursors.json
NAMI_EVENT_LOG_PATH=data/events.jsonl

# Membership payments (receiving side)
NAMI_PAYMENT_TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET
NAMI_USDC_COIN_TYPE=0x5d4b302506645c37ff133b98c4b50a5ae14864ca6ad8b9ee1c073dfa07d1f4b0::coin::COIN
NAMI_GOON_COIN_TYPE=0xc31be4b73d3352373c9e2d99e8620944f414b24407495b1d0c9f5628e2e86104::goon::GOON
NAMI_SUI_USD_PRICE=2.5
NAMI_PAYMENT_ALLOW_MOCK=true
NAMI_REQUIRE_WALLET_AUTH=false
NAMI_PAYMENT_SUCCESS_URL=http://localhost:5173/?payment=success
NAMI_PAYMENT_CANCEL_URL=http://localhost:5173/?payment=cancel

# Stripe (card)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NAMI_PAYPAL_MODE=sandbox