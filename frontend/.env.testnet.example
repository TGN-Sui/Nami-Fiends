# Official Nami testnet build — copy to .env.local before deploy
# Demo, fixture catalogs, and simulation surfaces are disabled when TEST_LAUNCH=true.

VITE_NAMI_NETWORK=testnet
VITE_NAMI_PACKAGE_ID=0xYOUR_PUBLISHED_PACKAGE_ID
VITE_NAMI_INDEXER_URL=https://your-receiving-server.example
VITE_NAMI_OFFICIAL_OWNER=0xYOUR_OFFICIAL_OWNER
VITE_NAMI_ADMIN_CAP_ID=0xYOUR_ADMIN_CAP_ID

# Required for testnet launch policy
VITE_NAMI_TEST_LAUNCH=true
VITE_NAMI_DEV_FIXTURES=false

# Do not set VITE_NAMI_DEMO_OWNER on official testnet builds

VITE_NAMI_REQUIRE_WALLET_AUTH=true

# zkLogin (register redirect URI for your testnet portal origin)
VITE_ZKLOGIN_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_ZKLOGIN_REDIRECT_URL=https://your-testnet-origin/
VITE_ZKLOGIN_SALT_URL=https://salt.api.mystenlabs.com/get_salt

# Payments (optional until checkout is live)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_PAYPAL_CLIENT_ID=...