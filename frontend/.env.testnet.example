# Official Nami testnet build — copy to .env.local before deploy
# Demo, fixture catalogs, and simulation surfaces are disabled when TEST_LAUNCH=true.

VITE_NAMI_NETWORK=testnet
# From deployments/testnet/latest.json (2026-06-13 publish — republish if contracts changed)
VITE_NAMI_PACKAGE_ID=0xd4ccad8f0687e31aaee2524db96c7a1d9509abaeadc949e0136c6522a631e058
VITE_NAMI_ADMIN_CAP_ID=0x170eaaa308ffb88096ebdc664bdcd27dc0a36ce42461fdb2422fb79657009edc
VITE_NAMI_PUBLISH_DIGEST=GpcDAktof53hT4nMbSKfVquKjhmaYYkuyVr9soPTwGpq
VITE_NAMI_INDEXER_URL=https://your-receiving-server.example
VITE_NAMI_OFFICIAL_OWNER=0xbcf5a725b72f88fd50c7146a48822fc61e3691cbe44193a668887de4573764ca
VITE_NAMI_OFFICIAL_OWNER_EMAIL=robbier640@gmail.com

# Required for testnet launch policy
VITE_NAMI_TEST_LAUNCH=true
VITE_NAMI_DEV_FIXTURES=false

# Do not set VITE_NAMI_DEMO_OWNER on official testnet builds

VITE_NAMI_REQUIRE_WALLET_AUTH=true

# zkLogin (register redirect URI for your testnet portal origin)
VITE_ZKLOGIN_CLIENT_ID=885352607900-cnbkebbo23ejlbabgvooshre535204qs.apps.googleusercontent.com
VITE_ZKLOGIN_REDIRECT_URL=http://localhost:5173/
VITE_ZKLOGIN_SALT_URL=https://salt.api.mystenlabs.com/get_salt

