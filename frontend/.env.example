# devnet | testnet | mainnet | localnet
VITE_NAMI_NETWORK=testnet

# Published Nami package ID after deployment
VITE_NAMI_PACKAGE_ID=0xYOUR_PACKAGE_ID_HERE

# Optional for localnet only
VITE_SUI_FULLNODE_URL=http://127.0.0.1:9000

# Phase 3 protocol wiring (read-only)
# Nami Official owner wallet — holds AdminCap and can manage moderators
VITE_NAMI_OFFICIAL_OWNER=0xYOUR_WALLET_ADDRESS_HERE

# Optional fallback owner when no wallet is connected in the browser
VITE_NAMI_DEMO_OWNER=0xYOUR_WALLET_ADDRESS_HERE

# AdminCap object ID from deployment (owner-only on-chain actions)
VITE_NAMI_ADMIN_CAP_ID=0xYOUR_ADMIN_CAP_ID_HERE

# Backend indexer read-only HTTP API (npm --prefix backend run dev)
VITE_NAMI_INDEXER_URL=http://127.0.0.1:8787

# Payment checkout (publishable keys surfaced via /api/payments/membership/config)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_PAYPAL_CLIENT_ID=...

# $GOON token coin type (defaults to canonical testnet type if unset)
# VITE_NAMI_GOON_COIN_TYPE=0xc31be4b73d3352373c9e2d99e8620944f414b24407495b1d0c9f5628e2e86104::goon::GOON

# Phase 5 zkLogin (Google OAuth — testnet/devnet)
# VITE_ZKLOGIN_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# VITE_ZKLOGIN_REDIRECT_URL=http://localhost:5173/
# VITE_ZKLOGIN_SALT_URL=https://salt.api.mystenlabs.com/get_salt